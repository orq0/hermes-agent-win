<Window
    x:Class="Hermes.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Hermes.C# - Your AI Teammate"
    Width="1400"
    Height="900">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Main Chat Area -->
            <ColumnDefinition Width="*" />
            <!-- Right Panel (Buddy, Tasks, Teams) -->
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <!-- Main Chat Area -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Background="{ThemeResource AccentFillColorDefaultBrush}" Padding="20">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="💻 Hermes.C#" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="ModeIndicator" Text="[Coordinator Mode]" FontSize="14" Foreground="White" Opacity="0.8" />
                    <TextBlock x:Name="SessionInfo" Text="" FontSize="14" Foreground="White" Opacity="0.8" />
                </StackPanel>
            </Border>

            <!-- Conversation Transcript -->
            <ScrollViewer x:Name="TranscriptScroll" Grid.Row="1" Padding="20">
                <ItemsControl x:Name="TranscriptItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5,0,10" Padding="15" CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="user">
                                                <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Margin="0,0,0,5">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource RoleToNameConverter}">
                                                <Binding Path="Role" />
                                                <Binding Path="ToolName" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="FreshnessWarning" 
                                               Text="{Binding FreshnessWarning}" 
                                               FontStyle="Italic" 
                                               Foreground="Orange" 
                                               Margin="0,5,0,0" 
                                               Visibility="{Binding FreshnessWarning, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="20" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                    <!-- Permission Mode Selector -->
                    <ComboBox Grid.Row="0" Grid.ColumnSpan="3" x:Name="PermissionModeSelector" 
                              Margin="0,0,0,10" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Default (Ask Everything)" Tag="Default" />
                        <ComboBoxItem Content="Plan Mode (Read-Only)" Tag="Plan" />
                        <ComboBoxItem Content="Auto (Read=Auto, Write=Ask)" Tag="Auto" />
                        <ComboBoxItem Content="Accept Edits (Workspace=Auto)" Tag="AcceptEdits" />
                        <ComboBoxItem Content="Bypass Permissions (DANGEROUS)" Tag="BypassPermissions" />
                    </ComboBox>

                    <!-- Message Input -->
                    <TextBox x:Name="MessageInput" Grid.Row="1" Grid.Column="0" 
                             PlaceholderText="Type your message..." 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap"
                             Height="80"
                             Margin="0,0,10,0" />

                    <!-- Send Button -->
                    <Button Grid.Row="1" Grid.Column="1" Content="Send" 
                            Click="SendButton_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="30,10" />

                    <!-- Stop Button -->
                    <Button Grid.Row="1" Grid.Column="2" Content="Stop" 
                            x:Name="StopButton"
                            Click="StopButton_Click"
                            Padding="20,10"
                            Margin="10,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- Right Panel -->
        <ScrollViewer Grid.Column="1" Padding="15">
            <StackPanel Spacing="20">
                <!-- Buddy Companion -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🎮 Your Buddy" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />
                        <TextBlock x:Name="BuddyAscii" 
                                   FontFamily="Consolas" 
                                   FontSize="14" 
                                   TextAlignment="Center" 
                                   Margin="0,0,0,10" />
                        <StackPanel x:Name="BuddyInfo" Visibility="Collapsed">
                            <TextBlock x:Name="BuddyName" FontWeight="Bold" FontSize="16" />
                            <TextBlock x:Name="BuddySpecies" FontStyle="Italic" />
                            <TextBlock x:Name="BuddyPersonality" TextWrapping="Wrap" Margin="0,5,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" Spacing="10">
                                <StackPanel>
                                    <TextBlock Text="INT" FontSize="10" />
                                    <ProgressBar x:Name="BuddyInt" Width="60" Height="10" Maximum="100" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="ENR" FontSize="10" />
                                    <ProgressBar x:Name="BuddyEnr" Width="60" Height="10" Maximum="100" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="CRT" FontSize="10" />
                                    <ProgressBar x:Name="BuddyCrt" Width="60" Height="10" Maximum="100" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="FRN" FontSize="10" />
                                    <ProgressBar x:Name="BuddyFrn" Width="60" Height="10" Maximum="100" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Active Skills -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📚 Active Skills" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />
                        <ItemsControl x:Name="ActiveSkillsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                            CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="White" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Tasks Panel -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="✅ Tasks" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />
                        <ItemsControl x:Name="TasksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                            BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Priority}" 
                                                           FontSize="10" 
                                                           Padding="4,2" 
                                                           CornerRadius="3">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Priority}" Value="urgent">
                                                                    <Setter Property="Background" Value="Red" />
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="high">
                                                                    <Setter Property="Background" Value="Orange" />
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <ProgressBar Value="{Binding Progress, Mode=OneWay}" 
                                                         Height="4" 
                                                         Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding Status}" FontSize="11" Foreground="Gray" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Team Status -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="👥 Team Status" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />
                        <ItemsControl x:Name="TeamMembersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                                        <Ellipse Width="30" Height="30">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Role}" FontSize="11" Foreground="Gray" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Dream Status -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="💭 Dream Consolidation" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing x:Name="DreamProgressRing" IsActive="False" Width="20" Height="20" />
                            <TextBlock x:Name="DreamStatus" Text="Idle" />
                        </StackPanel>
                        <TextBlock x:Name="LastConsolidation" FontSize="11" Foreground="Gray" Margin="0,5,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
